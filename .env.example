# =============================================================
# RetailMind Product Intelligence Agent — Environment Variables
# =============================================================
# Copy this file to .env and fill in your API key:
#   cp .env.example .env
#
# You need an API key from ONE of these providers:
#   - Google Gemini (free): https://aistudio.google.com/apikey
#   - OpenAI: https://platform.openai.com/api-keys
#   - Groq (free): https://console.groq.com/keys
#
# NEVER commit your .env file — it contains your secret key.
# =============================================================

# Your API key (required)
OPENAI_API_KEY=

# Model name
# For Gemini: gemini-2.5-flash
# For OpenAI: gpt-4o-mini
# For Groq: llama-3.3-70b-versatile
MODEL_NAME=gemini-2.5-flash

# API Base URL
# For Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
# For OpenAI: leave empty
# For Groq: https://api.groq.com/openai/v1
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
